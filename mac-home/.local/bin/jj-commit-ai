#!/usr/bin/env bash
set -euo pipefail

show_help() {
  cat <<'USAGE'
Usage: jj-commit-ai [options] [-- <jj commit/describe args>]

生成提交信息并可选直接 `jj commit`，或用 `jj describe -m` 更新描述。

Options:
  --model NAME         指定 Codex 模型（默认：$JJ_COMMIT_AI_MODEL 或 gpt-5）
  --max-bytes N        发送给模型的 diff 最大字节数（默认：$JJ_COMMIT_AI_MAX_BYTES 或 120000）
  --preview            仅打印生成结果，不提交
  --commit             直接提交（不再询问）
  --yes                等同 --commit
  --show-prompt        打印发送给模型的完整提示词
  --extra TEXT         追加一段实时指令到提示词
  --lang CODE          指定输出语言，如 zh、en（默认：zh）
  --chinese            快捷方式，等同 --lang zh
  --wrap-subject STYLE 自定义标题包装（例如 brackets、cn-brackets；默认：cn-brackets）
  --bracket-title      快捷方式，标题使用半角方括号[]
  --bracket-title-cn   快捷方式，标题使用全角方括号【】
  --reasoning-effort, -r V 设置 Codex 推理强度（默认 minimal；可选：minimal/low/medium/high）
  --api NAME           指定使用的 API 后端 (默认: codex，可选: gemini, claude, gemini-cli)
  --fallback           API 失败时回退到本地摘要（默认关闭）
  --no-fallback        明确禁用本地摘要回退（默认行为）
  --describe           使用 `jj describe -m` 应用生成的信息（默认作用于工作副本 @）
  --rev REV            描述模式下指定目标修订，隐式启用 --describe；等价传给
                       `jj describe -r REV`
  -h, --help           查看帮助

子命令：
  fill-empty           批量为描述为空、父提交描述非空的提交生成描述

环境变量：
  GEMINI_API_KEY            使用 gemini 后端时的 API Key
  JJ_COMMIT_AI_BACKEND      默认的 API 后端（默认 codex，可选 gemini, claude, gemini-cli）
  JJ_COMMIT_AI_CLAUDE_MODEL 使用 claude 后端时的模型（默认 sonnet）
  JJ_COMMIT_AI_GEMINI_CLI_MODEL 使用 gemini-cli 后端时的模型（可选）
  JJ_COMMIT_AI_MODEL        默认模型名称
  JJ_COMMIT_AI_MAX_BYTES    diff 上限
  JJ_COMMIT_AI_EXTRA_PROMPT 额外固定提示词
  JJ_COMMIT_AI_COMMAND      调用命令（默认：codex）
  JJ_COMMIT_AI_CLI_ARGS     额外传给 Codex CLI 的参数（以空格分隔；默认保持 Codex 自身策略）
  JJ_COMMIT_AI_DEBUG        非空时打印调试信息
  JJ_COMMIT_AI_LANG        默认输出语言（如 zh、en；默认 zh）
  JJ_COMMIT_AI_WRAP_SUBJECT 标题包装样式（默认 cn-brackets）
  JJ_COMMIT_AI_KEEP_HISTORY 非空时保留 Codex CLI 历史目录（默认使用隔离目录）
  JJ_COMMIT_AI_CODEX_HOME   自定义隔离目录根路径（默认：$HOME/.codex/jj-commit-ai）
  JJ_COMMIT_AI_CODEX_FALLBACK 指定无权限写入时的备选目录（默认使用 $TMPDIR/jj-commit-ai）
  JJ_COMMIT_AI_TRUNCATE_RETRY_MAX Codex 因超限失败时最多自动重试次数（默认 3）
  JJ_COMMIT_AI_TRUNCATE_RETRY_MIN_BYTES 自动重试时的最小 diff 截断字节（默认 8000）
USAGE
}

fill_empty_help() {
  cat <<'USAGE'
Usage: jj-commit-ai fill-empty [options] [-- <jj-commit-ai options> [-- <jj describe args>]]

查找描述为空、且所有父提交描述均非空的提交，并为其生成描述。

Options:
  --revset EXPR        搜索范围（默认：::@，当前工作副本的所有祖先）
  --limit N            最多处理前 N 个匹配提交
  -n, --dry-run        仅列出匹配提交，不执行描述
  -y, --yes            跳过确认（执行模式下生效）
  -h, --help           查看子命令帮助

子命令后的 `--` 可继续传递 `jj-commit-ai` 的常规参数（如 `--lang en`），
若再额外提供第二个 `--`，其后的参数会传递给底层的 `jj describe`。
USAGE
}

fill_empty_subcommand() {
  local revset='::@'
  local limit=0
  local dry_run=0
  local assume_yes=0
  local forwarded_opts=()
  local forwarded_jj_args=()
  local in_jj_args=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --revset)
        [[ $# -ge 2 ]] || { echo 'jj-commit-ai fill-empty: --revset 需要参数' >&2; return 2; }
        revset="$2"
        shift 2
        ;;
      --limit)
        [[ $# -ge 2 ]] || { echo 'jj-commit-ai fill-empty: --limit 需要参数' >&2; return 2; }
        if ! [[ "$2" =~ ^[0-9]+$ ]]; then
          echo 'jj-commit-ai fill-empty: --limit 必须为非负整数' >&2
          return 2
        fi
        limit="$2"
        shift 2
        ;;
      -n|--dry-run|--preview)
        dry_run=1
        shift
        ;;
      -y|--yes|--commit)
        assume_yes=1
        shift
        ;;
      --help|-h)
        fill_empty_help
        return 0
        ;;
      --)
        shift
        if (( in_jj_args )); then
          while [[ $# -gt 0 ]]; do
            forwarded_jj_args+=("$1")
            shift
          done
          break
        else
          in_jj_args=1
          while [[ $# -gt 0 ]]; do
            if [[ "$1" == "--" ]]; then
              shift
              while [[ $# -gt 0 ]]; do
                forwarded_jj_args+=("$1")
                shift
              done
              break 2
            fi
            forwarded_opts+=("$1")
            shift
          done
          break
        fi
        ;;
      *)
        if (( in_jj_args )); then
          forwarded_jj_args+=("$1")
        else
          forwarded_opts+=("$1")
        fi
        shift
        ;;
    esac
  done

  local template_candidates
  template_candidates='if(description == "" && parents.len() > 0, change_id ++ "\n", "")'

  local raw_candidates=""
  local tmp_err
  tmp_err=$(mktemp "${TMPDIR:-/tmp}/jj-fill-empty-err-XXXXXX")
  if ! raw_candidates=$(JJ_NO_PAGER=1 jj log --no-pager --no-graph -r "$revset" --template "$template_candidates" 2>"$tmp_err"); then
    if ! raw_candidates=$(JJ_NO_PAGER=1 jj log --no-graph -r "$revset" --template "$template_candidates" 2>>"$tmp_err"); then
      echo 'jj-commit-ai fill-empty: 无法执行 jj log，请确认当前目录位于 jj 仓库内且 revset 合法' >&2
      if [[ -s "$tmp_err" ]]; then
        echo '--- jj log 错误输出 ---' >&2
        cat "$tmp_err" >&2
        echo '----------------------' >&2
      fi
      rm -f "$tmp_err"
      return 1
    fi
  fi
  rm -f "$tmp_err"

  local -a all_candidates=()
  declare -A candidate_label=()
  declare -A candidate_seen=()
  declare -A raw_seen=()

  declare -A empty_cache=()
  is_commit_empty() {
    local cid="$1"
    if [[ -n "${empty_cache[$cid]+x}" ]]; then
      [[ "${empty_cache[$cid]}" == 'empty' ]]
      return $?
    fi
    local flag
    flag=$(JJ_NO_PAGER=1 jj log --no-graph -r "change_id($cid)" --template 'if(empty, "empty", "non")' 2>/dev/null || echo "empty")
    empty_cache[$cid]="$flag"
    [[ "$flag" == 'empty' ]]
  }

  local cand
  while IFS= read -r cand; do
    cand=${cand%$'\r'}
    cand=${cand//[[:space:]]/}
    [[ -z "$cand" ]] && continue
    if [[ -n "${raw_seen[$cand]+x}" ]]; then
      continue
    fi
    raw_seen[$cand]=1
    if is_commit_empty "$cand"; then
      continue
    fi
    candidate_seen[$cand]=1
    all_candidates+=("$cand")
    local label_value
    label_value=$(JJ_NO_PAGER=1 jj log --no-graph -r "change_id($cand)" --template 'change_id.short(12) ++ " [" ++ commit_id.short(12) ++ "]"' 2>/dev/null || true)
    if [[ -z "$label_value" ]]; then
      label_value="$cand"
    fi
    candidate_label[$cand]="$label_value"
  done <<< "$raw_candidates"

  if (( ${#all_candidates[@]} == 0 )); then
    echo 'jj-commit-ai fill-empty: 未找到符合条件的提交' >&2
    return 0
  fi

  declare -A parent_cache=()
  parent_cache_get() {
    local cid="$1"
    if [[ -n "${parent_cache[$cid]+x}" ]]; then
      printf '%s' "${parent_cache[$cid]}"
      return 0
    fi
    local parents_output
    parents_output=$(JJ_NO_PAGER=1 jj log --no-graph -r "parents(change_id($cid))" --template 'change_id ++ "\n"' 2>/dev/null || true)
    parent_cache[$cid]="$parents_output"
    printf '%s' "$parents_output"
  }

  declare -A scheduled=()
  local -a ordered=()

  while :; do
    local chosen=""
    for cand in "${all_candidates[@]}"; do
      [[ -n "${scheduled[$cand]+x}" ]] && continue
      local parents_raw
      parents_raw=$(parent_cache_get "$cand")
      if [[ -z "$parents_raw" ]]; then
        continue
      fi
      local ok=1
      local parent
      while IFS= read -r parent; do
        parent=${parent%$'\r'}
        parent=${parent//[[:space:]]/}
        [[ -z "$parent" ]] && continue
        if is_commit_empty "$parent"; then
          continue
        fi
        if [[ -n "${scheduled[$parent]+x}" ]]; then
          continue
        fi
        if [[ -n "${candidate_seen[$parent]+x}" ]]; then
          ok=0
          break
        fi
      done <<< "$parents_raw"
      if (( ok )); then
        chosen="$cand"
        break
      fi
    done

    [[ -z "$chosen" ]] && break

    scheduled[$chosen]=1
    ordered+=("$chosen")
    if (( limit > 0 && ${#ordered[@]} >= limit )); then
      break
    fi
  done

  if (( ${#ordered[@]} == 0 )); then
    echo 'jj-commit-ai fill-empty: 未找到符合条件的提交' >&2
    return 0
  fi

  echo "jj-commit-ai fill-empty: 找到 ${#ordered[@]} 个提交需要生成描述："
  local cid
  for cid in "${ordered[@]}"; do
    printf '  - %s\n' "${candidate_label[$cid]:-$cid}"
  done

  if (( dry_run )); then
    return 0
  fi

  if (( ! assume_yes )); then
    local reply
    read -r -p "是否为以上提交生成描述？[y/N] " reply
    case "$reply" in
      [yY]|[yY][eE][sS])
        ;;
      *)
        echo 'jj-commit-ai fill-empty: 已取消' >&2
        return 1
        ;;
    esac
  fi

  local child_opts=("${forwarded_opts[@]}")
  local need_auto_yes=1
  local opt
  for opt in "${child_opts[@]}"; do
    case "$opt" in
      --yes|--commit|-y|--preview|--dry-run|--message-only)
        need_auto_yes=0
        ;;
    esac
  done
  if (( need_auto_yes )); then
    child_opts=(--yes "${child_opts[@]}")
  fi

  local total=${#ordered[@]}
  local idx=0
  for cid in "${ordered[@]}"; do
    idx=$((idx + 1))
    local display="${candidate_label[$cid]:-$cid}"
    printf '[fill-empty] 处理 %s (%d/%d)\n' "$display" "$idx" "$total" >&2
    local cmd=("$0" --rev "change_id($cid)" "${child_opts[@]}")
    if (( ${#forwarded_jj_args[@]} )); then
      cmd+=(-- "${forwarded_jj_args[@]}")
    fi
    set +e
    "${cmd[@]}"
    local child_status=$?
    set -e
    if (( child_status != 0 )); then
      printf '[fill-empty] 失败 %s (%d/%d), exit=%d\n' "$display" "$idx" "$total" "$child_status" >&2
      return "$child_status"
    fi
  done

  return 0
}

if [[ $# -gt 0 && "$1" == "fill-empty" ]]; then
  shift
  fill_empty_subcommand "$@"
  exit $?
fi

MODEL=${JJ_COMMIT_AI_MODEL:-gpt-5}
MAX_BYTES=${JJ_COMMIT_AI_MAX_BYTES:-120000}
EXTRA_PROMPT=${JJ_COMMIT_AI_EXTRA_PROMPT:-}
CLI_COMMAND=${JJ_COMMIT_AI_COMMAND:-codex}
# 兼容误设别名：若显式设为 "dx"，视为 codex
if [[ "$CLI_COMMAND" == "dx" ]]; then
  CLI_COMMAND="codex"
fi
DEFAULT_CLI_ARGS=""
LANG_PREF=${JJ_COMMIT_AI_LANG:-zh}
SUBJECT_STYLE=${JJ_COMMIT_AI_WRAP_SUBJECT:-cn-brackets}
REASONING_EFFORT=${JJ_COMMIT_AI_REASONING_EFFORT:-minimal}
DEBUG=${JJ_COMMIT_AI_DEBUG:-}
API_BACKEND=${JJ_COMMIT_AI_BACKEND:-codex}

AUTO_COMMIT=0
PREVIEW_ONLY=0
ASSUME_YES=0
SHOW_PROMPT=0
EXTRA_RUNTIME_PROMPT=""
ENABLE_FALLBACK=0
JJ_ARGS=()
DESCRIBE_MODE=0
TARGET_REVISION_CLI=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model) 
      [[ $# -ge 2 ]] || { echo "jj-commit-ai: --model 需要参数" >&2; exit 2; }
      MODEL="$2"
      shift 2
      ;; 
    --max-bytes) 
      [[ $# -ge 2 ]] || { echo "jj-commit-ai: --max-bytes 需要参数" >&2; exit 2; }
      if ! [[ "$2" =~ ^[0-9]+$ ]]; then
        echo "jj-commit-ai: --max-bytes 必须为整数" >&2
        exit 2
      fi
      MAX_BYTES="$2"
      shift 2
      ;; 
    --preview|--dry-run|--message-only) 
      PREVIEW_ONLY=1
      shift
      ;; 
    --commit) 
      AUTO_COMMIT=1
      shift
      ;; 
    --yes|-y) 
      AUTO_COMMIT=1
      ASSUME_YES=1
      shift
      ;; 
    --show-prompt) 
      SHOW_PROMPT=1
      shift
      ;; 
    --extra) 
      [[ $# -ge 2 ]] || { echo "jj-commit-ai: --extra 需要参数" >&2; exit 2; }
      EXTRA_RUNTIME_PROMPT="$2"
      shift 2
      ;; 
    --api) 
      [[ $# -ge 2 ]] || { echo "jj-commit-ai: --api 需要参数" >&2; exit 2; }
      API_BACKEND="$2"
      shift 2
      ;; 
    --lang) 
      [[ $# -ge 2 ]] || { echo "jj-commit-ai: --lang 需要参数" >&2; exit 2; }
      LANG_PREF="$2"
      shift 2
      ;; 
    --chinese) 
      LANG_PREF="zh"
      shift
      ;; 
    --wrap-subject) 
      [[ $# -ge 2 ]] || { echo "jj-commit-ai: --wrap-subject 需要参数" >&2; exit 2; }
      SUBJECT_STYLE="$2"
      shift 2
      ;; 
    --bracket-title) 
      SUBJECT_STYLE="brackets"
      shift
      ;; 
    --bracket-title-cn) 
      SUBJECT_STYLE="cn-brackets"
      shift
      ;;
    --fallback) 
      ENABLE_FALLBACK=1
      shift
      ;;
    --no-fallback) 
      ENABLE_FALLBACK=0
      shift
      ;;
    --describe)
      DESCRIBE_MODE=1
      shift
      ;;
    --rev|--describe-revision)
      [[ $# -ge 2 ]] || { echo "jj-commit-ai: $1 需要参数" >&2; exit 2; }
      TARGET_REVISION_CLI="$2"
      DESCRIBE_MODE=1
      shift 2
      ;;
    --rev=*)
      TARGET_REVISION_CLI="${1#*=}"
      DESCRIBE_MODE=1
      shift
      ;;
    -r|--reason|--reasoning|--reasoning-effort) 
      [[ $# -ge 2 ]] || { echo "jj-commit-ai: $1 需要参数" >&2; exit 2; }
      REASONING_EFFORT="$2"
      shift 2
      ;; 
    -h|--help) 
      show_help
      exit 0
      ;; 
    --) 
      shift
      JJ_ARGS=("${@}")
      break
      ;; 
    *)
      JJ_ARGS+=("$1")
      shift
      ;; 
  esac
done

TARGET_REVISIONS=()
TARGET_REVISION=""
if [[ -n "$TARGET_REVISION_CLI" ]]; then
  TARGET_REVISIONS+=("$TARGET_REVISION_CLI")
fi
if (( DESCRIBE_MODE )); then
  i=0
  while (( i < ${#JJ_ARGS[@]} )); do
    arg="${JJ_ARGS[i]}"
    case "$arg" in
      -r|--revision)
        if (( i + 1 < ${#JJ_ARGS[@]} )); then
          TARGET_REVISIONS+=("${JJ_ARGS[i+1]}")
          ((i+=2))
        else
          ((i++))
        fi
        continue
        ;;
      --revision=*)
        rev="${arg#*=}"
        [[ -n "$rev" ]] && TARGET_REVISIONS+=("$rev")
        ((i++))
        continue
        ;;
      --repository=*|--config=*|--config-file=*|--at-operation=*|--at-op=*|--author=*|--message=*|--color=*|--template=*)
        ((i++))
        continue
        ;;
      -R|--repository|--config|--config-file|--at-operation|--at-op|--author|-T|--template|--message|--color)
        if (( i + 1 < ${#JJ_ARGS[@]} )); then
          ((i+=2))
        else
          ((i++))
        fi
        continue
        ;;
    esac
    if [[ "$arg" == --* ]]; then
      ((i++))
      continue
    fi
    if [[ "$arg" == -* ]]; then
      ((i++))
      continue
    fi
    TARGET_REVISIONS+=("$arg")
    ((i++))
  done

  if (( ${#TARGET_REVISIONS[@]} )); then
    declare -A __ami_target_seen=()
    filtered=()
    for rev in "${TARGET_REVISIONS[@]}"; do
      [[ -z "$rev" ]] && continue
      if [[ -z "${__ami_target_seen[$rev]:-}" ]]; then
        __ami_target_seen[$rev]=1
        filtered+=("$rev")
      fi
    done
    TARGET_REVISIONS=("${filtered[@]}")
    unset filtered __ami_target_seen
    TARGET_REVISION="${TARGET_REVISIONS[0]}"
    if (( ${#TARGET_REVISIONS[@]} > 1 )); then
      others=("${TARGET_REVISIONS[@]:1}")
      printf 'jj-commit-ai: 检测到多个修订，仅使用第一个 (%s)，忽略: %s\n' "$TARGET_REVISION" "${others[*]}" >&2
      unset others
    fi
    if ! jj log -r "$TARGET_REVISION" --limit=1 >/dev/null 2>&1; then
      printf 'jj-commit-ai: 无法解析修订 %s\n' "$TARGET_REVISION" >&2
      exit 1
    fi
  fi
fi

# 尝试找到 codex CLI（仅在使用 codex 后端时需要）
if [[ "$API_BACKEND" == "codex" ]]; then
  if ! command -v "$CLI_COMMAND" >/dev/null 2>&1; then
    if [[ -d "$HOME/.local/share/mise/shims" ]]; then
      PATH="$HOME/.local/share/mise/shims:$PATH"
    fi
  fi

  if ! command -v "$CLI_COMMAND" >/dev/null 2>&1; then
    if [[ -x "/opt/homebrew/bin/$CLI_COMMAND" ]]; then
      PATH="/opt/homebrew/bin:$PATH"
    elif [[ -x "/home/linuxbrew/.linuxbrew/bin/$CLI_COMMAND" ]]; then
      PATH="/home/linuxbrew/.linuxbrew/bin:$PATH"
    elif [[ -x "$HOME/.local/bin/$CLI_COMMAND" ]]; then
      PATH="$HOME/.local/bin:$PATH"
    fi
  fi

  if ! command -v "$CLI_COMMAND" >/dev/null 2>&1; then
    echo "jj-commit-ai: 找不到 $CLI_COMMAND，可设置 JJ_COMMIT_AI_COMMAND 自定义" >&2
    exit 127
  fi
fi

STATUS_LABEL="Repository status (jj status)"
STATUS_CMD=(jj status --color=never)
DIFF_STAT_LABEL="Diff summary (jj diff --stat)"
DIFF_STAT_CMD=(jj diff --stat --color=never)
DIFF_PATCH_LABEL="Diff (git format)"
DIFF_PATCH_CMD=(jj diff --git --color=never)

if (( DESCRIBE_MODE )) && [[ -n "$TARGET_REVISION" ]]; then
  TARGET_REV_LABEL="$TARGET_REVISION"
  printf -v STATUS_LABEL "Revision summary (jj show --summary -r '%s')" "$TARGET_REV_LABEL"
  STATUS_CMD=(jj show --summary --color=never "$TARGET_REVISION")
  printf -v DIFF_STAT_LABEL "Diff summary (jj diff --stat -r '%s')" "$TARGET_REV_LABEL"
  DIFF_STAT_CMD=(jj diff --stat --color=never -r "$TARGET_REVISION")
  printf -v DIFF_PATCH_LABEL "Diff (jj diff --git -r '%s')" "$TARGET_REV_LABEL"
  DIFF_PATCH_CMD=(jj diff --git --color=never -r "$TARGET_REVISION")
fi

STATUS_OUTPUT=$("${STATUS_CMD[@]}" 2>/dev/null || true)
DIFF_STAT=$("${DIFF_STAT_CMD[@]}" 2>/dev/null || true)
DIFF_OUTPUT=$("${DIFF_PATCH_CMD[@]}" 2>/dev/null || true)

trimmed_diff=$(printf '%s' "$DIFF_OUTPUT" | tr -d '\r\n\t ')
trimmed_stat=$(printf '%s' "$DIFF_STAT" | tr -d '\r\n\t ')
if [[ -z "$trimmed_diff" && -z "$trimmed_stat" ]]; then
  echo "jj-commit-ai: 没有检测到改动，退出" >&2
  exit 1
fi

DIFF_OUTPUT_RAW="$DIFF_OUTPUT"
DIFF_BYTES=$(printf '%s' "$DIFF_OUTPUT_RAW" | wc -c | tr -d ' ')

BASE_PROMPT_EN=$'You are an expert developer creating high-quality commit messages for the Jujutsu (jj) VCS.\nGuidelines:\n- Provide a concise subject line (<= 72 characters).\n- Make the subject specific and concrete; prefer user-visible behavior or feature area over file/module names. Avoid listing files or internal helper identifiers (unless they are user-facing commands). Avoid vague words like update, improve, fix.\n- Pack as many key points as feasible into the subject using compact separators (/, -, comma), while staying within 72 characters; if not possible, include the top 2–3 most important points.\n- Output only the commit message, with the subject on the first line; no preamble, meta text, disclaimers, or headings; do not write lines like "Here is...", "Drafting...", or "in Chinese".\n- Add at most 3 short bullets after a blank line; each bullet should be a single clause starting with a verb, avoid long chains (and/then/;), <= 80 characters.\n- No Markdown formatting (no bold/italics/headings) and no code fences or surrounding quotes.\n- Prioritise the most impactful changes if the diff is long.\n- Use sentence case for the subject.\n- Example (good): 【Unify source label and keep separators】; Example (bad): 【jj-commit-ai】.\n'
BASE_PROMPT="$BASE_PROMPT_EN"

if [[ -n "$LANG_PREF" ]]; then
  case "$LANG_PREF" in
    zh|zh-CN|zh-cn|cn|中文|简体中文) 
      BASE_PROMPT=$'你是一名资深开发者，需要为 Jujutsu (jj) 版本控制系统撰写高质量的提交信息。\n规范：\n- 提交标题不超过 72 个字符，使用简洁的陈述语气。\n- 标题需具体明确：优先描述“用户可见的行为/影响或功能区域”；除非是用户直接使用的命令名，否则不要把文件/模块名（尤其是 foo/bar 形式）当作标题主体；避免“更新/优化/修复”等过于抽象的词。\n- 标题尽可能涵盖本次修改的多个重点；可用“/、-、、”等紧凑分隔符串联，整体不超过 72 字符；若无法全部容纳，请保留 2–3 个最重要要点。\n- 只输出提交信息本身：首行直接给出标题；不要输出任何引导语/说明/免责声明/小标题；不要出现“以下是…/Here is/草拟/正在用中文”等字样。\n- 标题下方空一行后列出要点；最多 3 条，每条使用动宾短语且只包含一项结果，不要长句或多个“并且/以及”，长度不超过 80 字符。\n- 不要使用 Markdown 强调/标题/代码块（如 **、#、```），也不要在外层加引号。\n- 若改动较多，请突出最重要的影响。\n- 所有内容必须使用简体中文撰写；如模型生成了非中文，请立即用简体中文重新表述。\n- 示例（好的）：【统一来源标签并保留分隔线】；示例（不佳）：【jj-commit-ai】。\n'
      ;; 
    *) 
      BASE_PROMPT="${BASE_PROMPT_EN}Please write the subject line and bullet list in ${LANG_PREF}.\n"
      ;; 
  esac
fi

if [[ -n "$SUBJECT_STYLE" ]]; then
  case "$SUBJECT_STYLE" in
    brackets) 
      if [[ -n "$LANG_PREF" ]]; then
        case "$LANG_PREF" in
          zh|zh-CN|zh-cn|cn|中文|简体中文) 
            BASE_PROMPT+=$'\n请将提交标题整体放在半角方括号内，例如：[新增功能]。\n'
            ;; 
          *)
            BASE_PROMPT+=$'\nWrap the subject line in square brackets, e.g. [Subject Title].\n'
            ;; 
        esac
      else
        BASE_PROMPT+=$'\nWrap the subject line in square brackets, e.g. [Subject Title].\n'
      fi
      ;; 
    cn-brackets) 
      if [[ -n "$LANG_PREF" && $LANG_PREF =~ ^(zh|zh-CN|zh-cn|cn|中文|简体中文)$ ]]; then
        BASE_PROMPT+=$'\n请将提交标题整体放在全角方括号内，例如：【新增功能】。\n'
      else
        BASE_PROMPT+=$'\nWrap the subject line in full-width brackets, e.g. 【Subject Title】.\n'
      fi
      ;; 
    *)
      ;; 
  esac
fi

if [[ -n "$EXTRA_PROMPT" ]]; then
  BASE_PROMPT+=$'\nAdditional preferences:\n'
  BASE_PROMPT+="$EXTRA_PROMPT"
  BASE_PROMPT+=$'\n'
fi

if [[ -n "$EXTRA_RUNTIME_PROMPT" ]]; then
  BASE_PROMPT+=$'\nReal-time instructions:\n'
  BASE_PROMPT+="$EXTRA_RUNTIME_PROMPT"
  BASE_PROMPT+=$'\n'
fi

build_final_prompt() {
  local limit_bytes="$1"
  local diff_payload="$DIFF_OUTPUT_RAW"
  local truncated_flag=""
  if (( limit_bytes > 0 && DIFF_BYTES > limit_bytes )); then
    # 在 pipefail 下，head 提前结束会让上游 printf 收到 SIGPIPE(141)；这里允许该情况。
    diff_payload=$(printf '%s' "$DIFF_OUTPUT_RAW" | head -c "$limit_bytes" || true)
    truncated_flag=$'\n\n[Diff truncated to '
    truncated_flag+="$limit_bytes"
    truncated_flag+=$' bytes for AI prompt.]'
  fi

  PROMPT_BODY=$'\n'
  PROMPT_BODY+="$STATUS_LABEL"
  PROMPT_BODY+=$':\n'
  PROMPT_BODY+="$STATUS_OUTPUT"
  PROMPT_BODY+=$'\n\n'
  PROMPT_BODY+="$DIFF_STAT_LABEL"
  PROMPT_BODY+=$':\n'
  PROMPT_BODY+="$DIFF_STAT"
  PROMPT_BODY+=$'\n\n'
  PROMPT_BODY+="$DIFF_PATCH_LABEL"
  PROMPT_BODY+=$':\n'
  PROMPT_BODY+="$diff_payload"
  PROMPT_BODY+="$truncated_flag"

  FINAL_PROMPT="$BASE_PROMPT$PROMPT_BODY"
}

stdout_has_context_limit_error() {
  local stdout_file="$1"
  [[ -s "$stdout_file" ]] || return 1
  grep -Eiq 'context window|context length|context_length|token limit|too long|request too large|payload too large|input too large|max(imum)? input|413' "$stdout_file"
}

CURRENT_MAX_BYTES="$MAX_BYTES"
build_final_prompt "$CURRENT_MAX_BYTES"

if (( SHOW_PROMPT )) && [[ "$API_BACKEND" != "codex" ]]; then
  echo "===== AI PROMPT BEGIN ===="
  printf '%s\n' "$FINAL_PROMPT"
  echo "===== AI PROMPT END ===="
fi

COMMIT_MESSAGE=""
USING_FALLBACK=0
CLI_STATUS=0
MESSAGE_SOURCE=""

