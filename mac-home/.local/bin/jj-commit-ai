elif [[ "$API_BACKEND" == "gemini" ]]; then
    if [[ -z "${GEMINI_API_KEY:-}" ]]; then
        echo "jj-commit-ai: 使用 gemini 后端时，必须设置 GEMINI_API_KEY 环境变量" >&2
        exit 1
    fi

    set +e
    COMMIT_MESSAGE=$(JJ_COMMIT_AI_PROMPT="$FINAL_PROMPT" \
                     GEMINI_API_KEY="${GEMINI_API_KEY}" \
